# Public URL of the deployed site (used for SEO canonical URLs, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://www.filecount.sa

# Set to true on production host to allow search engine indexing (also auto-enabled on Vercel production)
# NEXT_PUBLIC_SITE_INDEXABLE=true

# Optional social handle for Twitter card metadata
# NEXT_PUBLIC_TWITTER_HANDLE=@filecount

# Google Analytics 4 measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console site verification token
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token

# Bing Webmaster Tools verification token
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-verification-token

# Microsoft Clarity project ID
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# Meta Pixel ID (optional)
# NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# LinkedIn Insight Tag partner ID (optional)
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=your-partner-id
